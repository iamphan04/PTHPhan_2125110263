void QuickSort(int a[], int l,int r) {
	int i = l, j = r, x;
	x = a[(l + r) / 2];
	do {
		while (a[i] < x) i++;
		while (a[j] > x) j--;
		if (i <= j) {
			swap(a[i], a[j]);
			i++;
			j--;
		}
	} while (i < j);
	if (l < j) {
		QuickSort(a,l, j);
	}
	if (i < r) {
		QuickSort(a,i, r);
	}
}
