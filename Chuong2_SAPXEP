void InsertionSort(int a[],int n) {
	int pos, x;
	for (int i = 1;i < n;i++) {
		pos = i;
		x = a[i];
		while (pos > 0 && a[pos - 1] > x) {
			a[pos] = a[pos - 1];
			pos--;
		}
		a[pos] = x;
	}
}
