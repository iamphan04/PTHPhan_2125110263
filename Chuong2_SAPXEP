void Shift(int a[], int l, int r) {
	int i, x, j;
	bool co = true;
	i = l;
	j = 2 * i + 1;
	x = a[i];
	while ((j <= r) && (co == true)) {
		if ((j < r) && (a[j] < a[j + 1])) {
			j++;
		}
		if (a[j] <= x) {
			co = false;
		}
		else {
			a[i] = a[j];
			i = j;
			j = 2 * i + 1;
		}
		
	}
	a[i] = x;
}
void CreateHeap(int a[], int n) {
	int l = n / 2 - 1;
	while (l >= 0) {
		Shift(a, l, n - 1);
		l--;
	}
}
void HeapSort(int a[], int n) {
	CreateHeap(a, n);
	int r = n - 1;
	while (r > 0) {
		swap(a[0], a[r]);
		r--;
		if (r > 0) {
			Shift(a, 0, r);
		}
	}
}
int main() {
	int n;
	int a[100];
	Nhap(a, n);
	HeapSort(a,n);
	Xuat(a, n);
	return 0;
}
